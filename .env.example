# =============================================================================
# Kaupet.no — Miljøvariabler
# =============================================================================
# Kopier denne filen til `.env` og fyll inn verdier for lokal kjøring.
# VITE_*-variabler er publishable (bundles inn i klienten). Alle andre er
# server-only og leses kun fra serverfunksjoner / SSR.
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase — OBLIGATORISK
# -----------------------------------------------------------------------------
# Klient + server bruker samme prosjekt. Publishable key er trygg i klienten;
# service role key må ALDRI eksponeres til frontend.

SUPABASE_PROJECT_ID=""
SUPABASE_URL=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""


# -----------------------------------------------------------------------------
# Vipps / MobilePay — kreves for betaling (promoteringer)
# -----------------------------------------------------------------------------
# `VIPPS_ENVIRONMENT` styrer hvilken nøkkelgruppe som brukes.
# Sett til "test" for å bruke VIPPS_TEST_*; ellers brukes produksjon.

VIPPS_ENVIRONMENT="test"

# Produksjon
VIPPS_CLIENT_ID=""
VIPPS_CLIENT_SECRET=""
VIPPS_SUBSCRIPTION_KEY=""
VIPPS_MSN=""
VIPPS_WEBHOOK_SECRET=""

# Test
VIPPS_TEST_CLIENT_ID=""
VIPPS_TEST_CLIENT_SECRET=""
VIPPS_TEST_SUBSCRIPTION_KEY=""
VIPPS_TEST_MSN=""
VIPPS_TEST_WEBHOOK_SECRET=""


# -----------------------------------------------------------------------------
# Push-varsler (Web Push / VAPID)
# -----------------------------------------------------------------------------
# Genereres med f.eks. `npx web-push generate-vapid-keys`.
# VAPID_SUBJECT er valgfri (default: mailto:post@kaupet.no).

VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:post@kaupet.no"


# -----------------------------------------------------------------------------
# Push-varsler (Android native / Firebase Cloud Messaging)
# -----------------------------------------------------------------------------
# Hentes fra Firebase Console -> Project Settings -> Service Accounts ->
# Generate new private key. Lim inn hele JSON-filens innhold som én linje.

FCM_SERVICE_ACCOUNT_JSON=""


# -----------------------------------------------------------------------------
# Diverse
# -----------------------------------------------------------------------------
# PUBLIC_SITE_URL brukes som fallback for absolutte URL-er (f.eks. i
# webhook-callbacks). La stå tom for å bruke relative URL-er.

PUBLIC_SITE_URL=""

# NODE_ENV settes vanligvis automatisk av Vite/runtime. Overstyr kun ved behov.
# NODE_ENV="development"
