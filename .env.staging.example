# =============================================================================
# Kaupet.no — Staging-miljøvariabler
# =============================================================================
# Brukes til å bygge/deploye staging-workeren (kaupet-no-staging, se
# wrangler.jsonc -> env.staging). Peker mot et EGET Supabase-prosjekt, ikke
# produksjonsprosjektet — opprett det separat i Supabase-dashbordet og kjør
# `supabase db push` (eller link det via `supabase link`) for å få med
# migrasjonene i supabase/migrations.
#
# Kopier til `.env.staging.local` for lokal bygging mot staging, eller sett
# tilsvarende variabler/secrets på GitHub Environment "staging".
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase — eget staging-prosjekt (IKKE samme som prod)
# -----------------------------------------------------------------------------

SUPABASE_PROJECT_ID=""
SUPABASE_URL=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""


# -----------------------------------------------------------------------------
# Vipps / MobilePay — bruk alltid testmiljøet i staging
# -----------------------------------------------------------------------------

VIPPS_ENVIRONMENT="test"

VIPPS_TEST_CLIENT_ID=""
VIPPS_TEST_CLIENT_SECRET=""
VIPPS_TEST_SUBSCRIPTION_KEY=""
VIPPS_TEST_MSN=""
VIPPS_TEST_WEBHOOK_SECRET=""


# -----------------------------------------------------------------------------
# Push-varsler (Web Push / VAPID)
# -----------------------------------------------------------------------------
# Egne VAPID-nøkler for staging, slik at testpush ikke kan forveksles med
# ekte prod-abonnenter. Genereres med `npx web-push generate-vapid-keys`.

VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:post@kaupet.no"


# -----------------------------------------------------------------------------
# Push-varsler (Android native / Firebase Cloud Messaging)
# -----------------------------------------------------------------------------
# Bruk samme Firebase-prosjekt som prod, eller et eget staging-prosjekt om
# testpush ikke skal nå ekte enheter.

FCM_SERVICE_ACCOUNT_JSON=""


# -----------------------------------------------------------------------------
# Diverse
# -----------------------------------------------------------------------------

PUBLIC_SITE_URL="https://staging.kaupet.no"
