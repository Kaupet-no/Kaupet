<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- API 31+ reads the splash screen background from the framework-namespaced
         attribute directly, so the compat attribute in values/styles.xml
         alone isn't enough on these versions. -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:windowSplashScreenBackground">@color/splashBackground</item>
    </style>
</resources>
